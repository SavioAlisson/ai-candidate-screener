# Copy to `.env` and fill in. Never commit the real .env.

# ── LLM (required) ─────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...            # https://console.anthropic.com

# ── Research / enrichment (required for full pipeline) ─────────────
APIFY_TOKEN=apify_api_...            # LinkedIn / posts / Crunchbase scraping
LINKUP_API_KEY=...                   # deep web search
GITHUB_TOKEN=ghp_...                 # GitHub sourcing + profile enrichment

# ── ATS integration (required to write results back) ───────────────
ASHBY_API_KEY=...                    # Ashby ATS — primary key
WAAS_ASHBY_API_KEY=...               # optional second key for outbound source tagging

# ── Slack intake bot (optional — slack_intake.py only) ─────────────
SLACK_BOT_TOKEN=xoxb-...             # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...             # App-Level Token (Socket Mode)
CATCH_UP_HOURS=48                    # startup catch-up scan window
